DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
JWT_SECRET="change_this_to_long_random_secret"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"
CRON_SECRET="optional_secret_for_cron_health_endpoint"
NUXT_PUBLIC_SITE_URL="http://localhost:3000"
# مدة تكرار إشعار الأقساط المستحقة بالدقائق. القيمة الافتراضية 5.
INSTALLMENT_ALERT_REPEAT_MINUTES=5
# عدد أيام الاحتفاظ بسجل محاولات إرسال الإشعارات.
NOTIFICATION_DELIVERY_KEEP_DAYS=30

NUXT_PUBLIC_ONESIGNAL_APP_ID=""
ONESIGNAL_REST_API_KEY=""
ONESIGNAL_SEND_TO_ALL=false

# OneSignal Production Notifications
NUXT_PUBLIC_ONESIGNAL_APP_ID=""
ONESIGNAL_REST_API_KEY=""
INSTALLMENT_ALERT_REPEAT_MINUTES="5"
# خليها false أو لا تضيفها حتى يرسل لكل الأجهزة المشتركة
ONESIGNAL_STRICT_USER_TARGETING="false"
